#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
删除 App.tsx 中的 HeroSection 函数定义（连同函数体一起删除）
"""

with open('App.tsx', 'r', encoding='utf-8') as f:
    content = f.read()

# 找到 HeroSection 函数的开始
start_marker = 'function HeroSection() {'
start_idx = content.find(start_marker)

if start_idx != -1:
    # 找到函数体开始 {
    func_start = content.find('{', start_idx)
    if func_start != -1:
        # 找到匹配的函数结束 }
        brace_count = 1
        end_idx = func_start + 1
        while brace_count > 0 and end_idx < len(content):
            if content[end_idx] == '{':
                brace_count += 1
            elif content[end_idx] == '}':
                brace_count -= 1
            end_idx += 1
        
        # 删除整个函数（包括前后的空白行）
        # 向前找到函数签名开始行
        line_start = content.rfind('\n', 0, start_idx) + 1
        
        # 向后找到函数结束 } 的下一行
        line_end = end_idx
        if line_end < len(content) and content[line_end] == '\n':
            line_end += 1
        
        # 删除函数
        content = content[:line_start] + content[line_end:]
        
        # 写回文件
        with open('App.tsx', 'w', encoding='utf-8') as f:
            f.write(content)
        
        print('HeroSection function DELETED successfully')
        print(f'  Removed {end_idx - line_start} characters')
    else:
        print('ERROR: Could not find function body start {')
else:
    print('WARNING: HeroSection function not found (might already be removed)')
