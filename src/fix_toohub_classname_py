#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
修复 TOONHUBHero.tsx 中 Line 266-273 的重复 className 属性
"""

with open('TOONHUBHero.tsx', 'r', encoding='utf-8') as f:
    lines = f.readlines()

# 找到重复的 className 行
# Line 266 (index 265): className="hidden sm:block"
# Line 273 (index 272): className="sm:mb-5 sm:text-sm"

# 策略：合并两个 className
fixed_lines = []
skip_next = False

for i, line in enumerate(lines):
    if skip_next:
        skip_next = False
        continue
    
    # 检查是否是第一个 className（后面会跟着第二个）
    if 'className="hidden sm:block"' in line and i + 7 < len(lines):
        # 检查后面几行是否有第二个 className
        next_non_empty = None
        for j in range(i+1, min(i+8, len(lines))):
            if lines[j].strip():
                next_non_empty = j
                break
        
        if next_non_empty and 'className="sm:mb-5 sm:text-sm"' in lines[next_non_empty]:
            # 合并！
            merged_class = '          className="hidden sm:block sm:mb-5 sm:text-sm"\n'
            fixed_lines.append(merged_class)
            skip_next = True  # 跳过第二个 className
            continue
    
    fixed_lines.append(line)

# 写回文件
with open('TOONHUBHero.tsx', 'w', encoding='utf-8') as f:
    f.writelines(fixed_lines)

print('Fixed duplicate className in TOONHUBHero.tsx')
print(f'Total lines: {len(fixed_lines)}')
