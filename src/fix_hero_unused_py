#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
注释掉 App.tsx 中的 HeroSection 函数（保留但标记为未使用）
"""

with open('App.tsx', 'r', encoding='utf-8') as f:
    content = f.read()

# 找到 HeroSection 函数的开始和结束
start_marker = 'function HeroSection() {'
start_idx = content.find(start_marker)

if start_idx != -1:
    # 找到函数体（从 { 开始）
    func_start = content.find('{', start_idx)
    if func_start != -1:
        # 找到匹配的函数结束 }
        brace_count = 1
        end_idx = func_start + 1
        while brace_count > 0 and end_idx < len(content):
            if content[end_idx] == '{':
                brace_count += 1
            elif content[end_idx] == '}':
                brace_count -= 1
            end_idx += 1
        
        # 注释掉整个函数
        commented = '/*\n' + content[start_idx:end_idx] + '\n*/'
        content = content[:start_idx] + commented + content[end_idx:]
        
        # 写回文件
        with open('App.tsx', 'w', encoding='utf-8') as f:
            f.write(content)
        
        print('HeroSection function commented out (preserved but unused)')
    else:
        print('ERROR: Could not find function body start {')
else:
    print('WARNING: HeroSection function not found (might already be removed)')
