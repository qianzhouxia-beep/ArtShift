#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
修复 TOONHUBHero.tsx 中的重复 className 属性（手动精确修复）
"""

with open('TOONHUBHero.tsx', 'r', encoding='utf-8') as f:
    content = f.read()

# 策略：找到重复的 className 并合并
# 问题：<p> 标签有2个 className 属性

# 方案：用正则表达式找到并修复
import re

# 匹配有2个 className 的 <p> 标签
pattern = r'className="hidden sm:block"\s+style\{\{[^}]+\}\}\s+className="sm:mb-5 sm:text-sm"'

# 替换为合并后的版本
replacement = 'className="hidden sm:block sm:mb-5 sm:text-sm"\n            style={{[^}]+}}'

# 使用 re.DOTALL 让 . 匹配换行符
content_fixed = re.sub(pattern, replacement, content, flags=re.DOTALL)

if content == content_fixed:
    print('WARNING: Pattern not found! Trying manual fix...')
    
    # 手动修复：直接替换文本
    old_text = '''            className="hidden sm:block"
            style={{
              fontSize: '12px',
              color: 'white',
              opacity: 0.85,
              lineHeight: 1.6,
              marginBottom: '16px',
            }}
            className="sm:mb-5 sm:text-sm"'''
    
    new_text = '''            className="hidden sm:block sm:mb-5 sm:text-sm"
            style={{
              fontSize: '12px',
              color: 'white',
              opacity: 0.85,
              lineHeight: 1.6,
              marginBottom: '16px',
            }}'''
    
    content = content.replace(old_text, new_text)
    print('Manual fix applied!')
else:
    content = content_fixed
    print('Regex fix applied!')

# 写回文件
with open('TOONHUBHero.tsx', 'w', encoding='utf-8') as f:
    f.write(content)

print('Fixed duplicate className in TOONHUBHero.tsx')
