#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
修复 TOONHUBHero.tsx 中的重复 className 属性
"""

with open('TOONHUBHero.tsx', 'r', encoding='utf-8') as f:
    lines = f.readlines()

# 找到重复的 className 并合并
fixed_lines = []
i = 0
while i < len(lines):
    line = lines[i]
    
    # 检查是否是重复的 className（下一个非空白行也是 className）
    if 'className=' in line and i + 1 < len(lines):
        # 查找下一个非空白行
        next_idx = i + 1
        while next_idx < len(lines) and lines[next_idx].strip() == '':
            next_idx += 1
        
        if next_idx < len(lines) and 'className=' in lines[next_idx]:
            # 找到重复！合并两个 className
            class1 = line.strip().split('className=')[1].strip()
            class2 = lines[next_idx].strip().split('className=')[1].strip()
            
            # 移除末尾的逗号或分号
            class1 = class1.rstrip(',').rstrip(';').strip()
            class2 = class2.rstrip(',').rstrip(';').strip()
            
            # 合并（移除引号，合并，重新加引号）
            if class1.startswith('"') and class1.endswith('"'):
                class1 = class1[1:-1]
            if class2.startswith('"') and class2.endswith('"'):
                class2 = class2[1:-1]
            
            merged = f'"{class1} {class2}"'
            indent = len(line) - len(line.lstrip())
            new_line = ' ' * indent + f'className={{merge}}'.replace('{{merge}}', merged)
            
            fixed_lines.append(new_line + '\n')
            i = next_idx + 1  # 跳过下一个 className
            continue
    
    fixed_lines.append(line)
    i += 1

# 写回文件
with open('TOONHUBHero.tsx', 'w', encoding='utf-8') as f:
    f.writelines(fixed_lines)

print('Fixed duplicate className attributes in TOONHUBHero.tsx')
print(f'Total lines: {len(fixed_lines)}')
